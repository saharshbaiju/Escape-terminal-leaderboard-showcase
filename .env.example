# Same Supabase project as the game. VITE_* values are public (baked into the
# bundle) — RLS keeps the publishable key read-only-safe.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=   # alternative to the publishable key
VITE_SUPABASE_TABLE=leaderboard
# Rows shown on the TV. Leave blank to show ALL runs (fill screen + scroll).
# Set a positive number only to cap it (e.g. VITE_TOP_N=10).
VITE_TOP_N=
# The game URL the "scan to play" QR code points to.
VITE_PLAY_URL=https://escapeterminal.vercel.app/
